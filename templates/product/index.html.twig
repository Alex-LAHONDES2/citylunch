<h1>Liste des produits</h1>

<div>
    {% for product in products %}
        <div style="border:1px solid #ccc; padding:10px; margin:10px;">
            <h2>{{ product.name }}</h2>
            <p>{{ product.description }}</p>
            <strong>{{ product.price }} €</strong>
        </div>
    {% endfor %}
</div>